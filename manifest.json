{
  "manifest_version": 3,
  "name": "TP Companion",
  "version": "1.1.0",
  "description": "Compañero para Trading Paints Pro: colores, paletas, logos simracing, generador de texturas y mood board.",
  "permissions": ["storage", "downloads", "tabs", "unlimitedStorage"],
  "host_permissions": [
    "https://*.tradingpaints.com/*",
    "https://commons.wikimedia.org/*",
    "https://upload.wikimedia.org/*",
    "https://*.wikipedia.org/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "panel/panel.html",
    "default_title": "TP Companion"
  },
  "content_scripts": [
    {
      "matches": ["https://*.tradingpaints.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
